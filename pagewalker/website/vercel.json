{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/discover", "destination": "/" },
    { "source": "/library", "destination": "/" },
    { "source": "/social", "destination": "/" },
    { "source": "/clubs", "destination": "/" },
    { "source": "/reader", "destination": "/" },
    { "source": "/profile", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ]
}
